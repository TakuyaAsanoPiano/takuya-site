---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogUrl?: string;
  ogType?: string;
}

const {
  title = "Takuya Asano | Piano, Composition, Sound Research",
  description = "The official website of Takuya Asano — a musician based in Japan, working with piano across post-classical, ambient, and electronic music.",
  ogImage = "https://asanotakuya.com/images/ddgrid.jpg",
  ogUrl = "https://asanotakuya.com/",
  ogType = "website"
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" type="image/svg+xml" href="/logo-t.svg" />
    <link rel="apple-touch-icon" href="/logo-t.png" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={ogUrl} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:site_name" content="Takuya Asano" />
    <meta property="og:locale" content="ja_JP" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <slot />
    <footer class="site-footer">
      <div class="container footer-inner">
        <nav class="footer-secondary">
          <a href="https://www.instagram.com/takuya_asano_/" target="_blank" rel="noopener noreferrer">Instagram</a>
          <a href="https://www.youtube.com/@TakuyaAsanoDD" target="_blank" rel="noopener noreferrer">YouTube</a>
          <a href="https://open.spotify.com/artist/2EXtaUmvzUTnfXZx14NoDx" target="_blank" rel="noopener noreferrer">Spotify</a>
          <a href="https://music.apple.com/jp/artist/%E6%B5%85%E9%87%8E%E8%A8%97%E7%9F%A2/1659347974" target="_blank" rel="noopener noreferrer">Apple Music</a>
          <a href="https://takuyaasano.bandcamp.com/music" target="_blank" rel="noopener noreferrer">Bandcamp</a>
        </nav>
        <p class="footer-copy">© Takuya Asano</p>
      </div>
    </footer>
  </body>
</html>
