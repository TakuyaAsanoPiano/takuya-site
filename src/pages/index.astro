---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Takuya Asano / 浅野託矢 | Piano, composition, and studies in sound"
  description="The official website of Takuya Asano — a musician based in Japan, working with piano across post-classical, ambient, and electronic music."
  ogImage="https://asanotakuya.com/images/ddgrid.jpg"
  ogUrl="https://asanotakuya.com/"
  ogType="website"
>
  <header class="site-header fade-in">
    <div class="container header-inner">
      <a href="/" class="site-title">Takuya Asano</a>
      <nav class="nav">
        <a href="/works">Works</a>
        <a href="/news">News</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="hero-bg"></div>
      <div class="container hero-inner fade-in">
        <h1>Takuya Asano</h1>
        <p class="hero-text">
          Piano, composition, and studies in sound.
        </p>
      </div>
    </section>

    <section class="section current-project">
      <div class="container narrow">
        <p class="section-kicker fade-in">Current Project</p>

        <div class="project-image-wrap fade-in">
          <img
            src="/images/cadinene-project.jpg"
            alt="Cadinene project image"
            class="project-image"
          />
        </div>

        <div class="project-body fade-in">
          <h2 class="project-title">Cadinene</h2>
          <p>A study of scent, time, and the fading contour of sound.</p>
          <p>An ongoing work exploring piano, repetition, and subtle shifts in texture.</p>
          <a href="/news/cadinene-project" class="text-link">Project note</a>
        </div>
      </div>
    </section>

    <section class="section latest-news">
      <div class="container narrow">
        <p class="section-kicker fade-in">Latest News</p>

        <ul class="news-list fade-in">
          <li>
            <span>2026.07.11</span>
            <div class="news-item-body">
              <p class="news-item-title">
                <a href="/news/akiuluminart-2026-ototoe">AKIULUMINART 2026 Closing Event: OTOTOE［音と絵］</a>
              </p>
            </div>
          </li>
          <li>
            <span>2026.06.28</span>
            <div class="news-item-body">
              <p class="news-item-title">
                <a href="/news/dd52-released">DD52 Released</a>
              </p>
            </div>
          </li>
          <li>
            <span>2026.06.21</span>
            <div class="news-item-body">
              <p class="news-item-title">
                <a href="/news/dd51-released">DD51 Released</a>
              </p>
            </div>
          </li>
        </ul>
      </div>
    </section>
  </main>

  <script is:inline>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
        }
      });
    }, { threshold: 0.12 });

    document.querySelectorAll(".fade-in").forEach((el) => observer.observe(el));
  </script>
  <style>
    .section-kicker {
      margin: 0 0 32px;
      font-family: "Cormorant Garamond", serif;
      font-size: 0.92rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
    }

    /* Current Project */
    .current-project {
      padding-bottom: 80px;
    }

    .project-image-wrap {
      margin-bottom: 40px;
    }

    .project-image {
      display: block;
      width: 100%;
      max-width: 480px;
      height: auto;
      filter: grayscale(8%);
      opacity: 0.93;
    }

    .project-title {
      margin: 0 0 16px;
      font-family: "Cormorant Garamond", serif;
      font-size: clamp(1.8rem, 3.5vw, 2.6rem);
      font-weight: 400;
      line-height: 1.12;
      letter-spacing: 0.01em;
    }

    .project-body p {
      max-width: 480px;
      color: #444444;
    }

    /* Latest News */
    .latest-news {
      padding-top: 0;
    }

    .latest-news .news-list {
      border-top: 1px solid var(--line);
    }

    .latest-news .news-list li:last-child {
      border-bottom: none;
    }

    .news-item-title {
      margin: 0;
      font-family: "Cormorant Garamond", serif;
      font-size: 1.18rem;
      font-weight: 400;
      letter-spacing: 0.01em;
    }

    .news-item-title a {
      transition: opacity 0.3s ease;
    }

    .news-item-title a:hover {
      opacity: 0.65;
    }

    @media (max-width: 640px) {
      .section-kicker {
        margin-bottom: 24px;
      }

      .project-image {
        max-width: 88%;
      }

      .project-image-wrap {
        margin-bottom: 32px;
      }

      .project-title {
        font-size: clamp(1.6rem, 6vw, 2rem);
      }
    }
  </style>
</Layout>
