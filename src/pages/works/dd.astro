---
import "../../styles/global.css";
---

<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="/logo-t.png" />

  <title>DD | Takuya Asano</title>
  <meta
    name="description"
    content="DD by Takuya Asano. The first album in an ongoing series of piano improvisations recorded in Miyagi."
  />

  <meta property="og:title" content="DD | Takuya Asano" />
  <meta
    property="og:description"
    content="DD by Takuya Asano. The first album in an ongoing series of piano improvisations recorded in Miyagi."
  />
  <meta property="og:image" content="https://takuya-site.gasudoro8.workers.dev/images/dd_album.jpg" />
  <meta property="og:type" content="article" />
  <meta property="og:url" content="https://takuya-site.gasudoro8.workers.dev/works/dd" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="DD | Takuya Asano" />
  <meta
    name="twitter:description"
    content="DD by Takuya Asano. The first album in an ongoing series of piano improvisations recorded in Miyagi."
  />
  <meta name="twitter:image" content="https://takuya-site.gasudoro8.workers.dev/images/dd_album.jpg" />
</head>

<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="site-title">Takuya Asano</a>
      <nav class="nav">
        <a href="/works">Works</a>
        <a href="/news">News</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </nav>
    </div>
  </header>

  <main class="section">
    <div class="container narrow">
      <p class="work-meta fade-in">2020 · Album</p>
      <h1 class="page-title fade-in">DD</h1>

      <p class="fade-in">
        The first collection from an ongoing diary of piano improvisations.
      </p>

      <div class="work-detail-image fade-in">
        <img src="/images/dd_album.jpg" alt="DD artwork" />
      </div>

      <div class="fade-in" style="margin-top: 72px;">
        <p>
          This album was made in my studio, located in a residential area of Miyagi, Japan.
        </p>

        <p>
          Every piece is an improvisation for piano.
        </p>

        <p>
          It marks the beginning of DD, an ongoing series of daily sketches, traces, and small observations in sound.
        </p>
      </div>

      <div class="fade-in" style="margin-top: 56px;">
        <p>
          The first album in an ongoing series of piano improvisations, recorded in Miyagi.
        </p>

        <p lang="ja">
          宮城の住宅街にあるスタジオで制作された、ピアノ即興演奏の最初の作品集です。<br />
          日々のスケッチのような記録として続いていく「DD」シリーズの出発点となっています。
        </p>
      </div>

      <div class="fade-in" style="margin-top: 72px;">
        <a
          href="https://open.spotify.com/intl-ja/album/7sLA1VmmxlqW8cSFZCGnSw?si=_C_OvGzmR5ighL1UcUHWHQ"
          class="text-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          Listen
        </a>
      </div>

      <div class="fade-in" style="margin-top: 80px;">
        <a href="/works" class="text-link">Back to Works</a>
      </div>
    </div>
  </main>

  <script is:inline>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
        }
      });
    }, { threshold: 0.12 });

    document.querySelectorAll(".fade-in").forEach((el) => observer.observe(el));
  </script>

  <footer class="site-footer">
    <div class="container footer-inner">
      <nav class="footer-secondary">
        <a href="https://www.instagram.com/takuya_asano_/" target="_blank" rel="noopener noreferrer">Instagram</a>
        <a href="https://www.youtube.com/@TakuyaAsanoDD" target="_blank" rel="noopener noreferrer">YouTube</a>
        <a href="https://open.spotify.com/artist/2EXtaUmvzUTnfXZx14NoDx" target="_blank" rel="noopener noreferrer">Spotify</a>
        <a href="https://music.apple.com/jp/artist/%E6%B5%85%E9%87%8E%E8%A8%97%E7%9F%A2/1659347974" target="_blank" rel="noopener noreferrer">Apple Music</a>
        <a href="https://takuyaasano.bandcamp.com/music" target="_blank" rel="noopener noreferrer">Bandcamp</a>
      </nav>
      <p class="footer-copy">© Takuya Asano</p>
    </div>
  </footer>
</body>
</html>
