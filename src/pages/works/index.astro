---
import "../../styles/global.css";

const works = [
  {
    title: "Cinnamon",
    year: "2023",
    description: "A quiet collection of piano-centered works shaped by memory, air, and delicate resonance.",
    image: "/images/cinnamon.jpg",
    link: "/works/cinnamon"
  },
  {
    title: "Cucumber",
    year: "2024",
    description: "Fragments of post-classical and ambient textures, observed as small, shifting phenomena.",
    image: "/images/cucumber.jpg",
    link: "/works/cucumber"
  }
];
---

<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Works | Takuya Asano</title>
  <meta
    name="description"
    content="Selected works by Takuya Asano, including post-classical piano pieces and recordings shaped by silence, texture, and careful attention to sound."
  />

  <meta property="og:title" content="Works | Takuya Asano" />
  <meta
    property="og:description"
    content="Selected works by Takuya Asano, including post-classical piano pieces and recordings shaped by silence, texture, and careful attention to sound."
  />
  <meta property="og:image" content="https://takuya-site.gasudoro8.workers.dev/images/ddgrid.jpg" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://takuya-site.gasudoro8.workers.dev/works" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Works | Takuya Asano" />
  <meta
    name="twitter:description"
    content="Selected works by Takuya Asano, including post-classical piano pieces and recordings shaped by silence, texture, and careful attention to sound."
  />
  <meta name="twitter:image" content="https://takuya-site.gasudoro8.workers.dev/images/ddgrid.jpg" />
</head>

  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="site-title">Takuya Asano</a>
        <nav class="nav">
          <a href="/works">Works</a>
          <a href="/news">News</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
        </nav>
      </div>
    </header>

    <main class="section">
      <div class="container">
        <h1 class="section-title">Works</h1>

        <div class="works-list">
          {works.map((work) => (
            <article class="work-item fade-in">
              <div class="work-image-wrap">
                <img src={work.image} alt={work.title} class="work-image" />
              </div>

              <div class="work-content">
                <p class="work-meta">{work.year}</p>
                <h3>{work.title}</h3>
                <p>{work.description}</p>
                <a href={work.link} class="text-link">View</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </main>

    <script is:inline>
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
          }
        });
      }, { threshold: 0.12 });

      document.querySelectorAll(".fade-in").forEach((el) => observer.observe(el));
    </script>

    <footer class="site-footer">
      <div class="container footer-inner">
        <nav class="footer-secondary">
         <a href="https://www.instagram.com/takuya_asano_/" target="_blank" rel="noopener noreferrer">Instagram</a>
         <a href="https://www.youtube.com/@TakuyaAsanoDD" target="_blank" rel="noopener noreferrer">YouTube</a>
         <a href="https://open.spotify.com/artist/2EXtaUmvzUTnfXZx14NoDx" target="_blank" rel="noopener noreferrer">Spotify</a>
         <a href="https://music.apple.com/jp/artist/%E6%B5%85%E9%87%8E%E8%A8%97%E7%9F%A2/1659347974" target="_blank" rel="noopener noreferrer">Apple Music</a>
         <a href="https://takuyaasano.bandcamp.com/music" target="_blank" rel="noopener noreferrer">Bandcamp</a>
       </nav>

        <p class="footer-copy">© Takuya Asano</p>
      </div>
    </footer>
  </body>
</html>
