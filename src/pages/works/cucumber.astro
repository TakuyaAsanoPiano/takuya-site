---
import "../../styles/global.css";
---

<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Cucumber | Takuya Asano</title>
  <meta
    name="description"
    content="Cucumber by Takuya Asano. A post-classical piano work shaped through light, air, and subtle repetition."
  />

  <meta property="og:title" content="Cucumber | Takuya Asano" />
  <meta
    property="og:description"
    content="Cucumber by Takuya Asano. A post-classical piano work shaped through light, air, and subtle repetition."
  />
  <meta property="og:image" content="https://takuya-site.gasudoro8.workers.dev/images/cucumber.jpg" />
  <meta property="og:type" content="article" />
  <meta property="og:url" content="https://takuya-site.gasudoro8.workers.dev/works/cucumber" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Cucumber | Takuya Asano" />
  <meta
    name="twitter:description"
    content="Cucumber by Takuya Asano. A post-classical piano work shaped through light, air, and subtle repetition."
  />
  <meta name="twitter:image" content="https://takuya-site.gasudoro8.workers.dev/images/cucumber.jpg" />
</head>

<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="site-title">Takuya Asano</a>
      <nav class="nav">
        <a href="/works">Works</a>
        <a href="/news">News</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </nav>
    </div>
  </header>

  <main class="section">
    <div class="container narrow">
      <p class="work-meta fade-in">2024 · Album</p>
      <h1 class="page-title fade-in">Cucumber</h1>

      <p class="fade-in">
        A piano work shaped around light and nostalgia.
      </p>

      <div class="work-detail-image fade-in">
        <img src="/images/cucumber.jpg" alt="Cucumber artwork" />
      </div>

      <div class="fade-in" style="margin-top: 72px;">
        <p>
          Soft, simple tones.<br />
          Light after rain, the scent of soil, and the quiet warmth of evening.
        </p>

        <p>
          The pieces move between memory and light,<br />
          tracing a small landscape that feels both distant and close.
        </p>
      </div>

      <div class="fade-in" style="margin-top: 56px;">
        <p>
          A piano-based album exploring light and nostalgia through subtle shifts in tone and texture.<br />
          Released in 2024.
        </p>

        <p lang="ja">
          「光と懐かしさ」をテーマにしたピアノソロ作品。<br />
          雨上がりの光や土の匂い、夕方の記憶を辿るように構成されています。
        </p>
      </div>

      <div class="fade-in" style="margin-top: 72px;">
        <a
          href="https://open.spotify.com/intl-ja/album/4IVimRBXTYQ9xs8mhmwPcq?si=-RoC5FZLQKGRDJQfpYnT6Q"
          class="text-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          Listen
        </a>
      </div>

      <div class="fade-in" style="margin-top: 80px;">
        <a href="/works" class="text-link">Back to Works</a>
      </div>
    </div>
  </main>

  <script is:inline>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
        }
      });
    }, { threshold: 0.12 });

    document.querySelectorAll(".fade-in").forEach((el) => observer.observe(el));
  </script>

  <footer class="site-footer">
    <div class="container footer-inner">
      <nav class="footer-secondary">
        <a href="https://www.instagram.com/takuya_asano_/" target="_blank" rel="noopener noreferrer">Instagram</a>
        <a href="https://www.youtube.com/@TakuyaAsanoDD" target="_blank" rel="noopener noreferrer">YouTube</a>
        <a href="https://open.spotify.com/artist/2EXtaUmvzUTnfXZx14NoDx" target="_blank" rel="noopener noreferrer">Spotify</a>
        <a href="https://music.apple.com/jp/artist/%E6%B5%85%E9%87%8E%E8%A8%97%E7%9F%A2/1659347974" target="_blank" rel="noopener noreferrer">Apple Music</a>
        <a href="https://takuyaasano.bandcamp.com/music" target="_blank" rel="noopener noreferrer">Bandcamp</a>
      </nav>
      <p class="footer-copy">© Takuya Asano</p>
    </div>
  </footer>
</body>
</html>
