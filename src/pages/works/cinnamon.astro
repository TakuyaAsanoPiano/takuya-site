---
import "../../styles/global.css";
---

<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="/logo-t.png" />
  <link rel="canonical" href="https://asanotakuya.com/works/cinnamon" />

  <title>Cinnamon | Takuya Asano</title>
  <meta
    name="description"
    content="Cinnamon by Takuya Asano. A post-classical piano work shaped through rain, memory, and restrained movement."
  />

  <meta property="og:title" content="Cinnamon | Takuya Asano" />
  <meta
    property="og:description"
    content="Cinnamon by Takuya Asano. A post-classical piano work shaped through rain, memory, and restrained movement."
  />
  <meta property="og:image" content="https://asanotakuya.com/images/cinnamon.jpg" />
  <meta property="og:type" content="article" />
  <meta property="og:url" content="https://asanotakuya.com/works/cinnamon" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Cinnamon | Takuya Asano" />
  <meta
    name="twitter:description"
    content="Cinnamon by Takuya Asano. A post-classical piano work shaped through rain, memory, and restrained movement."
  />
  <meta name="twitter:image" content="https://asanotakuya.com/images/cinnamon.jpg" />
</head>

<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="site-title">Takuya Asano</a>
      <nav class="nav">
        <a href="/works">Works</a>
        <a href="/news">News</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </nav>
    </div>
  </header>

  <main class="section">
    <div class="container narrow">
      <p class="work-meta fade-in">2023 · Album</p>
      <h1 class="page-title fade-in">Cinnamon</h1>

      <p class="fade-in">
        A quiet collection of piano-centered works shaped by memory, air, and delicate resonance.
      </p>

      <div class="work-detail-image fade-in">
        <img src="/images/cinnamon.jpg" alt="Cinnamon artwork" />
      </div>

      <div class="fade-in" style="margin-top: 72px;">
        <p>
          A piano work shaped around rain and nostalgia.
        </p>

        <p>
          Soft, quiet tones.<br />
          A memory of rain, and the scent of cinnamon.
        </p>

        <p>
          Not only the past —<br />
          even this moment already feels like something remembered.
        </p>
      </div>

      <div class="fade-in" style="margin-top: 56px;">
        <p>
          A piano-based album exploring rain and nostalgia through quiet resonance.<br />
          Released in 2023.
        </p>

        <p lang="ja">
          「雨と懐かしさ」を軸にしたピアノソロ作品。<br />
          記憶や空気の気配を、静かな音で辿るように構成されています。
        </p>
      </div>

      <div class="fade-in" style="margin-top: 72px;">
        <a
          href="https://open.spotify.com/intl-ja/album/6A5pULVzu0iCRGuUa0X3fq?si=-c2S8dAiR96qa8734iNlgA"
          class="text-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          Listen
        </a>
      </div>

      <div class="fade-in" style="margin-top: 80px;">
        <a href="/works" class="text-link">Back to Works</a>
      </div>
    </div>
  </main>

  <script is:inline>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
        }
      });
    }, { threshold: 0.12 });

    document.querySelectorAll(".fade-in").forEach((el) => observer.observe(el));
  </script>

  <footer class="site-footer">
    <div class="container footer-inner">
      <nav class="footer-secondary">
        <a href="https://www.instagram.com/takuya_asano_/" target="_blank" rel="noopener noreferrer">Instagram</a>
        <a href="https://www.youtube.com/@TakuyaAsanoDD" target="_blank" rel="noopener noreferrer">YouTube</a>
        <a href="https://open.spotify.com/artist/2EXtaUmvzUTnfXZx14NoDx" target="_blank" rel="noopener noreferrer">Spotify</a>
        <a href="https://music.apple.com/jp/artist/%E6%B5%85%E9%87%8E%E8%A8%97%E7%9F%A2/1659347974" target="_blank" rel="noopener noreferrer">Apple Music</a>
        <a href="https://takuyaasano.bandcamp.com/music" target="_blank" rel="noopener noreferrer">Bandcamp</a>
      </nav>
      <p class="footer-copy">© Takuya Asano / 浅野託矢</p>
    </div>
  </footer>
</body>
</html>
