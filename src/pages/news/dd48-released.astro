---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="DD48 released | News | Takuya Asano"
  description="A new piece from the DD series, DD48, is now available on Bandcamp."
  ogImage="https://asanotakuya.com/images/DD48.jpg"
  ogUrl="https://asanotakuya.com/news/dd48-released"
  ogType="article"
>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="site-title">Takuya Asano</a>
      <nav class="nav">
        <a href="/works">Works</a>
        <a href="/news">News</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </nav>
    </div>
  </header>

  <main class="section">
    <div class="container narrow">
      <article class="news-post">
        <a href="/news" class="back-link fade-in">← Back to News</a>

        <header class="news-post-header fade-in">
          <p class="news-date">2026.04.23</p>
          <h1 class="news-post-title">DD48 released</h1>
        </header>

        <figure class="news-post-image fade-in">
          <img src="/images/DD48.jpg" alt="DD48 artwork" />
        </figure>

        <div class="news-post-content fade-in">
          <p>A new piece from the DD series, DD48, is now available on Bandcamp.</p>

          <p>
            Developed during the Cadinene process, DD48 traces a gradual shift
            from something bright and exotic toward something more familiar and
            lived-in. The piece moves between freshness and nostalgia, carried
            by a slightly worn piano and a quietly unsettled harmony.
          </p>

          <p>
            <a
              href="https://takuyaasano.bandcamp.com/track/dd48"
              target="_blank"
              rel="noopener noreferrer"
            >
              Listen on Bandcamp
            </a>
          </p>
        </div>
      </article>
    </div>
  </main>

  <script is:inline>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
        }
      });
    }, { threshold: 0.12 });

    document.querySelectorAll(".fade-in").forEach((el) => observer.observe(el));
  </script>

  <footer class="site-footer">
    <div class="container footer-inner">
      <nav class="footer-secondary">
        <a href="https://www.instagram.com/takuya_asano_/" target="_blank" rel="noopener noreferrer">Instagram</a>
        <a href="https://www.youtube.com/@TakuyaAsanoDD" target="_blank" rel="noopener noreferrer">YouTube</a>
        <a href="https://open.spotify.com/artist/2EXtaUmvzUTnfXZx14NoDx" target="_blank" rel="noopener noreferrer">Spotify</a>
        <a href="https://music.apple.com/jp/artist/%E6%B5%85%E9%87%8E%E8%A8%97%E7%9F%A2/1659347974" target="_blank" rel="noopener noreferrer">Apple Music</a>
        <a href="https://takuyaasano.bandcamp.com/music" target="_blank" rel="noopener noreferrer">Bandcamp</a>
      </nav>

      <p class="footer-copy">© Takuya Asano / 浅野託矢</p>
    </div>
  </footer>

  <style>
    .news-post {
      max-width: 720px;
      margin: 0 auto;
    }

    .back-link {
      display: inline-block;
      margin-bottom: 40px;
      color: var(--muted);
      font-size: 0.95rem;
      transition: opacity 0.3s ease;
    }

    .back-link:hover {
      opacity: 0.65;
    }

    .news-post-header {
      margin-bottom: 32px;
    }

    .news-date {
      margin: 0 0 12px;
      color: var(--muted);
      font-size: 0.92rem;
      letter-spacing: 0.04em;
    }

    .news-post-title {
      margin: 0;
      font-family: "Cormorant Garamond", "Noto Serif JP", serif;
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.12;
      font-weight: 400;
      letter-spacing: 0.01em;
    }

    .news-post-image {
      margin: 0 0 40px;
    }

    .news-post-image img {
      display: block;
      width: 100%;
      max-width: 560px;
      height: auto;
      margin: 0 auto;
      border-radius: 2px;
    }

    .news-post-content {
      max-width: 560px;
      margin: 0 auto;
    }

    .news-post-content p {
      margin: 0 0 20px;
      font-family: "Cormorant Garamond", "Noto Serif JP", serif;
      font-size: 1.08rem;
      line-height: 1.72;
      letter-spacing: 0.008em;
      color: #333333;
    }

    .news-post-content a {
      transition: opacity 0.3s ease;
    }

    .news-post-content a:hover {
      opacity: 0.65;
    }

    @media (max-width: 640px) {
      .back-link {
        margin-bottom: 32px;
        font-size: 0.92rem;
      }

      .news-post-header {
        margin-bottom: 24px;
      }

      .news-post-image {
        margin-bottom: 28px;
      }

      .news-post-image img {
        max-width: 100%;
      }

      .news-post-content {
        max-width: 100%;
      }

      .news-post-content p {
        font-size: 1rem;
        line-height: 1.68;
      }
    }
  </style>
</Layout>
