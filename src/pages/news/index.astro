---
import Layout from "../../layouts/Layout.astro";

const news = [
  {
    date: "2026.04.11",
    title: "山の和",
    note: "A live performance is scheduled in Akiu, Sendai.",
    link: "/news/yamanowa"
  },
  {
    date: "2026.03.20",
    title: "Website updated",
    note: "A quiet structural update to the website.",
    link: "/news/website-updated"
  },
  {
    date: "2026.03.10",
    title: "New work released",
    note: "A new work has been added to the ongoing archive.",
    link: "/news/new-work"
  }
];
---

<Layout
  title="News | Takuya Asano"
  description="Notes on releases, performances, and quiet updates from Takuya Asano."
  ogImage="https://asanotakuya.com/images/ddgrid.jpg"
  ogUrl="https://asanotakuya.com/news"
  ogType="website"
>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="site-title">Takuya Asano</a>
      <nav class="nav">
        <a href="/works">Works</a>
        <a href="/news">News</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </nav>
    </div>
  </header>

  <main class="section">
    <div class="container narrow">
      <header class="news-header fade-in">
        <h1 class="section-title">News</h1>
        <p class="news-intro">Recent notes on releases, updates, and performances.</p>
      </header>

      <ul class="news-list">
        {news.map((item) => (
          <li class="fade-in">
            <span>{item.date}</span>
            <div class="news-item-body">
              <p class="news-item-title">
                <a href={item.link}>{item.title}</a>
              </p>
              <p class="news-item-note">{item.note}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </main>

  <script is:inline>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
        }
      });
    }, { threshold: 0.12 });

    document.querySelectorAll(".fade-in").forEach((el) => observer.observe(el));
  </script>

  <footer class="site-footer">
    <div class="container footer-inner">
      <nav class="footer-secondary">
        <a href="https://www.instagram.com/takuya_asano_/" target="_blank" rel="noopener noreferrer">Instagram</a>
        <a href="https://www.youtube.com/@TakuyaAsanoDD" target="_blank" rel="noopener noreferrer">YouTube</a>
        <a href="https://open.spotify.com/artist/2EXtaUmvzUTnfXZx14NoDx" target="_blank" rel="noopener noreferrer">Spotify</a>
        <a href="https://music.apple.com/jp/artist/%E6%B5%85%E9%87%8E%E8%A8%97%E7%9F%A2/1659347974" target="_blank" rel="noopener noreferrer">Apple Music</a>
        <a href="https://takuyaasano.bandcamp.com/music" target="_blank" rel="noopener noreferrer">Bandcamp</a>
      </nav>

      <p class="footer-copy">© Takuya Asano / 浅野託矢</p>
    </div>
  </footer>

  <style>
    .news-header {
      margin-bottom: 56px;
    }

    .news-intro {
      margin: -28px 0 0;
      max-width: 34rem;
      color: var(--muted);
    }

    .news-item-body {
      min-width: 0;
    }

    .news-item-title {
      margin: 0;
      font-family: "Cormorant Garamond", serif;
      font-size: 1.28rem;
      line-height: 1.45;
      font-weight: 400;
      letter-spacing: 0.01em;
    }

    .news-item-title a {
      transition: opacity 0.3s ease;
    }

    .news-item-title a:hover {
      opacity: 0.65;
    }

    .news-item-note {
      margin: 8px 0 0;
      color: var(--muted);
      font-size: 0.96rem;
      line-height: 1.8;
    }

    @media (max-width: 640px) {
      .news-header {
        margin-bottom: 44px;
      }

      .news-intro {
        margin-top: -30px;
        font-size: 0.94rem;
        line-height: 1.8;
      }

      .news-item-title {
        font-size: 1.16rem;
        line-height: 1.5;
      }

      .news-item-note {
        margin-top: 6px;
        font-size: 0.92rem;
        line-height: 1.75;
      }
    }
  </style>
</Layout>
