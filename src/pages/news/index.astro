---
import "../../styles/global.css";

const news = [
  {
    date: "2026.03.20",
    title: "Website updated",
    note: "A quiet structural update to the website.",
    link: "/news/website-updated"
  },
  {
    date: "2026.03.10",
    title: "New work released",
    note: "A new work has been added to the ongoing archive.",
    link: "/news/new-work"
  }
];
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>News | Takuya Asano</title>
  <meta
    name="description"
    content="Notes on releases, performances, and quiet updates from Takuya Asano."
  />

  <meta property="og:title" content="News | Takuya Asano" />
  <meta
    property="og:description"
    content="Notes on releases, performances, and quiet updates from Takuya Asano."
  />
  <meta property="og:image" content="https://takuya-site.gasudoro8.workers.dev/images/ddgrid.jpg" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://takuya-site.gasudoro8.workers.dev/news" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="News | Takuya Asano" />
  <meta
    name="twitter:description"
    content="Notes on releases, performances, and quiet updates from Takuya Asano."
  />
  <meta name="twitter:image" content="https://takuya-site.gasudoro8.workers.dev/images/ddgrid.jpg" />
</head>

<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="site-title">Takuya Asano</a>
      <nav class="nav">
        <a href="/works">Works</a>
        <a href="/news">News</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </nav>
    </div>
  </header>

  <main class="news-page">
    <div class="container news-container">
      <header class="news-header fade-in">
        <p class="news-label">News</p>
        <h1 class="news-title">Recent notes on releases, updates, and performances.</h1>
      </header>

      <ul class="news-list">
        {news.map((item) => (
          <li class="news-item fade-in">
            <a href={item.link} class="news-link">
              <div class="news-meta">
                <span class="news-date">{item.date}</span>
              </div>

              <h2>{item.title}</h2>
              <p class="news-note">{item.note}</p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </main>

  <script is:inline>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
        }
      });
    }, { threshold: 0.12 });

    document.querySelectorAll(".fade-in").forEach((el) => observer.observe(el));
  </script>

  <footer class="site-footer">
    <div class="container footer-inner">
      <nav class="footer-secondary">
        <a href="https://www.instagram.com/takuya_asano_/" target="_blank" rel="noopener noreferrer">Instagram</a>
        <a href="https://www.youtube.com/@TakuyaAsanoDD" target="_blank" rel="noopener noreferrer">YouTube</a>
        <a href="https://open.spotify.com/artist/2EXtaUmvzUTnfXZx14NoDx" target="_blank" rel="noopener noreferrer">Spotify</a>
        <a href="https://music.apple.com/jp/artist/%E6%B5%85%E9%87%8E%E8%A8%97%E7%9F%A2/1659347974" target="_blank" rel="noopener noreferrer">Apple Music</a>
        <a href="https://takuyaasano.bandcamp.com/music" target="_blank" rel="noopener noreferrer">Bandcamp</a>
      </nav>

      <p class="footer-copy">© Takuya Asano</p>
    </div>
  </footer>
</body>
</html>

<style>
  .news-page {
    padding: 9rem 0 6rem;
  }

  .news-container {
    max-width: 760px;
  }

  .news-header {
    margin-bottom: 4.5rem;
  }

  .news-label {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.55;
    margin-bottom: 1rem;
  }

  .news-title {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    line-height: 1.55;
    font-weight: 400;
    letter-spacing: 0.01em;
    max-width: 12ch;
  }

  .news-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid rgba(0, 0, 0, 0.12);
  }

  .news-item {
    border-bottom: 1px solid rgba(0, 0, 0, 0.12);
  }

  .news-link {
    display: block;
    padding: 2rem 0;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.25s ease;
  }

  .news-link:hover {
    opacity: 0.7;
  }

  .news-meta {
    margin-bottom: 0.75rem;
  }

  .news-date {
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    opacity: 0.55;
  }

  .news-item h2 {
    font-size: clamp(1.2rem, 2vw, 1.55rem);
    line-height: 1.5;
    font-weight: 400;
    margin: 0 0 0.65rem;
  }

  .news-note {
    font-size: 0.97rem;
    line-height: 1.9;
    opacity: 0.72;
    max-width: 36rem;
    margin: 0;
  }

  @media (max-width: 768px) {
    .news-page {
      padding: 7rem 0 4.5rem;
    }

    .news-header {
      margin-bottom: 3rem;
    }

    .news-title {
      max-width: none;
      line-height: 1.6;
    }

    .news-link {
      padding: 1.5rem 0;
    }

    .news-item h2 {
      line-height: 1.55;
    }

    .news-note {
      font-size: 0.94rem;
      line-height: 1.85;
    }
  }
</style>
