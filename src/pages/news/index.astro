---
import Layout from "../../layouts/Layout.astro";

const news = [
  {
    date: "2026.07.11",
    title: "AKIULUMINART 2026 Closing Event: OTOTOE［音と絵］",
    note: "I will perform piano as part of OTOTOE［音と絵］ at GREAT DANE BREWING in Akiu.",
    link: "/news/akiuluminart-2026-ototoe"
  },
  {
    date: "2026.06.28",
    title: "DD52 Released",
    note: "A study of pinene, the first breath inside the forest, and the body remembering before thought.",
    link: "/news/dd52-released"
  },
  {
    date: "2026.06.21",
    title: "DD51 Released",
    note: "A study of inward change, β-elemene, and a chord held before transformation becomes an event.",
    link: "/news/dd51-released"
  },
  {
    date: "2026.06.14",
    title: "DD50 Released",
    note: "A new piece from the DD series is now available on Bandcamp.",
    link: "/news/dd50-released"
  },
  {
    date: "2026.06.07",
    title: "DD49 Released",
    note: "A new piece from the DD series is now available on Bandcamp.",
    link: "/news/dd49-released"
  },
  {
    date: "2026.04.23",
    title: "DD48 released",
    note: "A new piece from the DD series, now available on Bandcamp.",
    link: "/news/dd48-released"
  },
  {
    date: "2026.04.11",
    title: "山の和",
    note: "A live performance is scheduled in Akiu, Sendai.",
    link: "/news/yamanowa"
  },
  {
    date: "2026.03.29",
    title: "DD47 released",
    note: "A quiet study of evaporation and shifting contours.",
    link: "/news/dd47-released"
  },
  {
    date: "2026.03.20",
    title: "Website updated",
    note: "A quiet structural update to the website.",
    link: "/news/website-updated"
  },
  {
    date: "2026.03.10",
    title: "New work released",
    note: "A new work has been added to the ongoing archive.",
    link: "/news/new-work"
  }
];
---

<Layout
  title="News | Takuya Asano"
  description="Notes on releases, performances, and quiet updates from Takuya Asano."
  ogImage="https://asanotakuya.com/images/ddgrid.jpg"
  ogUrl="https://asanotakuya.com/news"
  ogType="website"
>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="site-title">Takuya Asano</a>
      <nav class="nav">
        <a href="/works">Works</a>
        <a href="/news">News</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </nav>
    </div>
  </header>

  <main class="section">
    <div class="container narrow">
      <header class="news-header fade-in">
        <h1 class="section-title">News</h1>
        <p class="news-intro">Recent notes on releases, updates, and performances.</p>
      </header>

      <ul class="news-list">
        {news.map((item) => (
          <li class="fade-in">
            <span>{item.date}</span>
            <div class="news-item-body">
              <p class="news-item-title">
                <a href={item.link}>{item.title}</a>
              </p>
              <p class="news-item-note">{item.note}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </main>

  <script is:inline>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
        }
      });
    }, { threshold: 0.12 });

    document.querySelectorAll(".fade-in").forEach((el) => observer.observe(el));
  </script>
  <style>
    .news-header {
      margin-bottom: 56px;
    }

    .news-intro {
      margin: -28px 0 0;
      max-width: 34rem;
      color: var(--muted);
    }

    .news-item-body {
      min-width: 0;
    }

    .news-item-title {
      margin: 0;
      font-family: "Cormorant Garamond", serif;
      font-size: 1.28rem;
      line-height: 1.45;
      font-weight: 400;
      letter-spacing: 0.01em;
    }

    .news-item-title a {
      transition: opacity 0.3s ease;
    }

    .news-item-title a:hover {
      opacity: 0.65;
    }

    .news-item-note {
      margin: 8px 0 0;
      color: var(--muted);
      font-size: 0.96rem;
      line-height: 1.8;
    }

    @media (max-width: 640px) {
      .news-header {
        margin-bottom: 44px;
      }

      .news-intro {
        margin-top: -30px;
        font-size: 0.94rem;
        line-height: 1.8;
      }

      .news-item-title {
        font-size: 1.16rem;
        line-height: 1.5;
      }

      .news-item-note {
        margin-top: 6px;
        font-size: 0.92rem;
        line-height: 1.75;
      }
    }
  </style>
</Layout>
