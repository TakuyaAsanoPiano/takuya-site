---
import "../../styles/global.css";
---

<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Website Updated | Takuya Asano</title>
  <meta
    name="description"
    content="An update on the official website of Takuya Asano, with refinements to structure, presentation, and access to works."
  />

  <meta property="og:title" content="Website Updated | Takuya Asano" />
  <meta
    property="og:description"
    content="An update on the official website of Takuya Asano, with refinements to structure, presentation, and access to works."
  />
  <meta property="og:image" content="https://takuya-site.gasudoro8.workers.dev/images/ddgrid.jpg" />
  <meta property="og:type" content="article" />
  <meta property="og:url" content="https://takuya-site.gasudoro8.workers.dev/news/website-updated" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Website Updated | Takuya Asano" />
  <meta
    name="twitter:description"
    content="An update on the official website of Takuya Asano, with refinements to structure, presentation, and access to works."
  />
  <meta name="twitter:image" content="https://takuya-site.gasudoro8.workers.dev/images/ddgrid.jpg" />
</head>

  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="site-title">Takuya Asano</a>
        <nav class="nav">
          <a href="/works">Works</a>
          <a href="/news">News</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
        </nav>
      </div>
    </header>

    <main class="section">
      <div class="container narrow">

        <p class="work-meta fade-in">2026.03.20</p>
        <h1 class="page-title fade-in">Website updated</h1>

        <div class="fade-in">
          <p>
            The website structure has been updated to create a clearer archive for works.
          </p>

          <p>
            The Works section is now organized into an index and individual pages, allowing a quieter and more focused navigation.
          </p>

          <p>
            News, About, and Contact have also been arranged as separate pages as the site continues to take shape.
          </p>
        </div>

        <div class="fade-in" style="margin-top: 80px;">
          <a href="/news" class="text-link">Back to News</a>
        </div>

      </div>
    </main>

    <script is:inline>
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
          }
        });
      }, { threshold: 0.12 });

      document.querySelectorAll(".fade-in").forEach((el) => observer.observe(el));
    </script>

    <footer class="site-footer">
      <div class="container footer-inner">
        <nav class="footer-secondary">
          <a href="https://www.instagram.com/takuya_asano_/" target="_blank" rel="noopener noreferrer">Instagram</a>
          <a href="https://www.youtube.com/@TakuyaAsanoDD" target="_blank" rel="noopener noreferrer">YouTube</a>
          <a href="https://open.spotify.com/artist/2EXtaUmvzUTnfXZx14NoDx" target="_blank" rel="noopener noreferrer">Spotify</a>
          <a href="https://music.apple.com/jp/artist/%E6%B5%85%E9%87%8E%E8%A8%97%E7%9F%A2/1659347974" target="_blank" rel="noopener noreferrer">Apple Music</a>
          <a href="https://takuyaasano.bandcamp.com/music" target="_blank" rel="noopener noreferrer">Bandcamp</a>
        </nav>

        <p class="footer-copy">© Takuya Asano</p>
      </div>
    </footer>

  </body>
</html>
