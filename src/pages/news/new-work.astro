---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="New work | News | Takuya Asano"
  description="A new work by Takuya Asano, 浅野託矢, has been released. A quiet note from the News archive."
  ogImage="https://asanotakuya.com/images/ddgrid.jpg"
  ogUrl="https://asanotakuya.com/news/new-work"
  ogType="article"
>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="site-title">Takuya Asano</a>
      <nav class="nav">
        <a href="/works">Works</a>
        <a href="/news">News</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </nav>
    </div>
  </header>

  <main class="section">
    <div class="container narrow">
      <article class="news-article fade-in">
        <p class="news-article-date">2026.03.20</p>
        <h1 class="section-title">New work</h1>

        <p class="news-article-intro-en">
          A new work has been released.
        </p>

        <div class="news-article-body">
          <p>
            新しい作品を公開しました。
          </p>
          <p>
            詳細は Works ページよりご覧いただけます。
          </p>
          <p>
            小さな記録のひとつとして、静かにアーカイブに加わりました。
          </p>
        </div>

        <p class="news-article-note-en">
          The archive continues to grow slowly, one work at a time.
        </p>

        <p class="news-back-link">
          <a href="/news">Back to News</a>
        </p>
      </article>
    </div>
  </main>

  <script is:inline>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
        }
      });
    }, { threshold: 0.12 });

    document.querySelectorAll(".fade-in").forEach((el) => observer.observe(el));
  </script>

  <footer class="site-footer">
    <div class="container footer-inner">
      <nav class="footer-secondary">
        <a href="https://www.instagram.com/takuya_asano_/" target="_blank" rel="noopener noreferrer">Instagram</a>
        <a href="https://www.youtube.com/@TakuyaAsanoDD" target="_blank" rel="noopener noreferrer">YouTube</a>
        <a href="https://open.spotify.com/artist/2EXtaUmvzUTnfXZx14NoDx" target="_blank" rel="noopener noreferrer">Spotify</a>
        <a href="https://music.apple.com/jp/artist/%E6%B5%85%E9%87%8E%E8%A8%97%E7%9F%A2/1659347974" target="_blank" rel="noopener noreferrer">Apple Music</a>
        <a href="https://takuyaasano.bandcamp.com/music" target="_blank" rel="noopener noreferrer">Bandcamp</a>
      </nav>

      <p class="footer-copy">© Takuya Asano / 浅野託矢</p>
    </div>
  </footer>

  <style>
    .news-article-date {
      margin: 0 0 18px;
      font-family: "Cormorant Garamond", serif;
      font-size: 1rem;
      color: var(--muted);
    }

    .news-article-intro-en {
      margin: -24px 0 32px;
      max-width: 32rem;
      color: var(--muted);
    }

    .news-article-body {
      display: grid;
      gap: 1.2rem;
      max-width: 38rem;
    }

    .news-article-body p {
      margin: 0;
      line-height: 1.95;
    }

    .news-article-note-en {
      margin: 36px 0 0;
      max-width: 34rem;
      font-size: 0.95rem;
      line-height: 1.8;
      color: var(--muted);
    }

    .news-back-link {
      margin-top: 48px;
    }

    .news-back-link a {
      display: inline-block;
      text-decoration: none;
      border-bottom: 1px solid currentColor;
      padding-bottom: 2px;
      transition: opacity 0.3s ease;
    }

    .news-back-link a:hover {
      opacity: 0.65;
    }

    @media (max-width: 640px) {
      .news-article-intro-en {
        margin-top: -28px;
        margin-bottom: 28px;
        font-size: 0.94rem;
        line-height: 1.8;
      }

      .news-article-body p {
        line-height: 1.9;
      }

      .news-article-note-en {
        margin-top: 32px;
        font-size: 0.92rem;
        line-height: 1.75;
      }

      .news-back-link {
        margin-top: 40px;
      }
    }
  </style>
</Layout>
