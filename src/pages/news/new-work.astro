---
import "../../styles/global.css";
---

<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New work released — Takuya Asano</title>
  </head>

  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="site-title">Takuya Asano</a>
        <nav class="nav">
          <a href="/works">Works</a>
          <a href="/news">News</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
        </nav>
      </div>
    </header>

    <main class="section">
      <div class="container narrow">

        <p class="work-meta fade-in">2026.03.10</p>
        <h1 class="page-title fade-in">New work released</h1>

        <div class="fade-in">
          <p>
            A new work has been added as part of the ongoing archive and release flow.
          </p>

          <p>
            The site is being rebuilt gradually so that each work can be viewed with more space, clearer structure, and quieter movement.
          </p>

          <p>
            Further updates to Works, News, and other pages will continue in the same direction.
          </p>
        </div>

        <div class="fade-in" style="margin-top: 80px;">
          <a href="/news" class="text-link">← Back to News</a>
        </div>

      </div>
    </main>

    <script is:inline>
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
          }
        });
      }, { threshold: 0.12 });

      document.querySelectorAll(".fade-in").forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
